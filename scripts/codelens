#!/usr/bin/env bash
# CodeLens MCP launcher — runs the Rust binary
set -euo pipefail

PROJECT_ROOT="${1:-.}"
PROJECT_ROOT="$(cd "$PROJECT_ROOT" && pwd)"
shift 2>/dev/null || true

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

RUST_BIN="$REPO_ROOT/rust/target/release/codelens-mcp"
if [ -x "$RUST_BIN" ]; then
    exec "$RUST_BIN" "$PROJECT_ROOT" "$@"
fi

echo "Error: Rust binary not found at $RUST_BIN" >&2
echo "Build with: cd rust && cargo build --release" >&2
exit 1
