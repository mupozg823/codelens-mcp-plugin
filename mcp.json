{
  "name": "codelens",
  "display_name": "CodeLens MCP",
  "description": "Pure Rust MCP server for code intelligence — 62 tools, 25 languages, tree-sitter-first, zero external dependencies",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "repository": "https://github.com/mupozg823/codelens-mcp-plugin",
  "homepage": "https://github.com/mupozg823/codelens-mcp-plugin",
  "authors": ["mupozg823"],
  "keywords": ["code-intelligence", "tree-sitter", "mcp", "lsp", "ai"],
  "categories": ["developer-tools"],
  "transport": "stdio",
  "install": {
    "shell": "curl -fsSL https://raw.githubusercontent.com/mupozg823/codelens-mcp-plugin/main/install.sh | bash",
    "homebrew": "brew install mupozg823/tap/codelens-mcp",
    "cargo": "cargo install --git https://github.com/mupozg823/codelens-mcp-plugin codelens-mcp"
  },
  "config": {
    "command": "codelens-mcp",
    "args": [".", "--preset", "balanced"],
    "env": {}
  },
  "clients": {
    "claude-code": {
      "type": "stdio",
      "command": "codelens-mcp",
      "args": [".", "--preset", "balanced"]
    },
    "claude-desktop": {
      "type": "stdio",
      "command": "codelens-mcp",
      "args": [".", "--preset", "balanced"]
    },
    "cursor": {
      "command": "codelens-mcp",
      "args": [".", "--preset", "balanced"]
    },
    "vscode": {
      "type": "stdio",
      "command": "codelens-mcp",
      "args": [".", "--preset", "balanced"]
    }
  }
}
