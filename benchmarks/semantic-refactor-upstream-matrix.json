          "tool": "rename_symbol",
          "env": {
            "CODELENS_ROSLYN_ADAPTER_CMD": "dotnet",
            "CODELENS_ROSLYN_ADAPTER_ARGS": "run --quiet --project adapters/roslyn-workspace-service/CodeLens.Roslyn.WorkspaceService"
