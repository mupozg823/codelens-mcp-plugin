# Rust
target/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Python generated files
__pycache__/
*.py[cod]
.venv/

# IDE
.idea/
.vscode/
*.iml

# CodeLens runtime (recursive — catches crates/*/.codelens/ too)
**/.codelens/**
!/.codelens/
!/.codelens/eval-session-audit-gate.json
.codelens-port

# Serena runtime
**/.serena/

# ML model cache
**/.fastembed_cache/

# Gradle (orphaned legacy)
.gradle/

# Environment
.env
.env.local

# Claude Code local settings (per-developer)
.claude/settings.local.json

# Agent worktrees (subagent isolation copies — not source of truth)
.claire/
.claude/worktrees/
models/.venv/
models/codelens-code-search/
models/benchmark_results.json
models/benchmark_hard_results.json
models/benchmark_full_results.json
scripts/finetune/output/

# ONNX model files (downloaded at install time)
*.onnx
*.onnx.bak
checkpoints/

# Backup copies of bundled embedding models — kept locally for A/B comparison
# but never shipped in releases. Only the active model (e.g. codesearch/) is tracked.
crates/codelens-engine/models/codesearch-v*-backup/
scripts/finetune/*.jsonl
scripts/finetune/gate-results/
scripts/finetune/external/
scripts/finetune/pipelines/

# Generated release-quality matrix run artifacts. Curated benchmark reports under
# benchmarks/results/*.json or *.md can still be committed explicitly.
benchmarks/results/*-release-quality-matrix/
